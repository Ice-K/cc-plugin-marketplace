{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-flow-kit.local/schemas/traceability.schema.json",
  "title": "spec-flow-kit traceability",
  "type": "object",
  "required": [
    "featureId",
    "version",
    "links"
  ],
  "properties": {
    "featureId": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "requirementId",
          "designIds",
          "taskIds",
          "code",
          "tests",
          "evidence",
          "status"
        ],
        "properties": {
          "requirementId": {
            "type": "string"
          },
          "designIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "taskIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "code": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tests": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "pass",
              "partial",
              "blocked",
              "failed"
            ]
          },
          "_comment": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "_comment": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
