{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-flow-kit.local/schemas/waivers.schema.json",
  "title": "spec-flow-kit waivers",
  "type": "object",
  "required": [
    "version",
    "waivers"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "waivers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "scope",
          "target",
          "reason",
          "status",
          "createdAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "scope": {
            "type": "string",
            "enum": [
              "gate",
              "rule",
              "traceability",
              "evidence",
              "task",
              "requirement"
            ]
          },
          "target": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "approvedBy": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "proposed",
              "approved",
              "expired",
              "revoked"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "expiresAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "reviewBy": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          },
          "_comment": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "_comment": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
