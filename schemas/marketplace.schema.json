{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claude Code Marketplace Manifest",
  "type": "object",
  "required": ["name", "description", "plugins"],
  "additionalProperties": true,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "owner": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "source"],
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "category": {
            "type": "string"
          },
          "source": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object"
              }
            ]
          },
          "homepage": {
            "type": "string"
          }
        }
      }
    }
  }
}
